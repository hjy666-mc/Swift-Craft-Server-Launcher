    "addplayer.info.line1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Offline accounts do not require network verification and can play games without an internet connection"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 离线账户无需网络验证，可以在没有网络的情况下游戏"
          }
        }
      }
    },
    "addplayer.info.line2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• The player name length is 1-16 characters, and can only contain letters, numbers, and underscores."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 玩家名长度为1-16个字符，只能包含字母、数字和下划线"
          }
        }
      }
    },
    "addplayer.info.line3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Offline accounts cannot be used on the official server."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 离线账户无法在正版服务器中使用"
          }
        }
      }
    },
    "addplayer.info.line4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• Each player name can only create one offline account"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "• 每个玩家名只能创建一个离线账户"
